# Ignore everything by default
*

# Keep gitignore itself
!.gitignore
!requirements.txt
!README.md

# Track only Python source files in home_energy_opt
!home_energy_opt/
!home_energy_opt/**/*.py

# Track only CSV files in data
!data/
!data/**/*.csv

# Track selected utility scripts (source only)
!scripts/
!scripts/regression_persistent_mpc.py
!scripts/plot_dashboard_from_outputs.py
